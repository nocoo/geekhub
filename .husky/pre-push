#!/usr/bin/env bash
# pre-push: production build + L1 coverage gate + L3 API E2E
set -euo pipefail

echo "==> pre-push: running production build..."
bun run build

echo "==> pre-push: running coverage check..."
bash scripts/check-coverage.sh

echo "==> pre-push: running API E2E tests..."
bash scripts/run-api-e2e.sh

echo "==> pre-push: all checks passed."
